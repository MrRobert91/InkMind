# Copia este archivo a .env y configura al menos un proveedor de IA.
# Desde la página "Configuración IA" de la app puedes elegir qué proveedor
# y qué modelo se usa para cada tarea (chat, estructura, edición, informe).

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=

# --- OpenAI ---
OPENAI_API_KEY=

# --- OpenRouter (acceso a cientos de modelos) ---
OPENROUTER_API_KEY=

# --- Groq ---
GROQ_API_KEY=

# --- xAI (Grok) ---
XAI_API_KEY=

# --- NVIDIA NIM (build.nvidia.com) ---
NVIDIA_API_KEY=

# --- Hugging Face (router de inferencia) ---
HF_TOKEN=

# --- Ollama local (no necesita clave) ---
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

# --- Cualquier endpoint compatible con la API de OpenAI ---
# CUSTOM_OPENAI_BASE_URL=https://mi-servidor/v1
# CUSTOM_OPENAI_API_KEY=

# Orígenes permitidos para CORS (por defecto: cualquiera)
# CORS_ORIGINS=http://localhost:3000
